# Firebase Client SDK Config
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Local backend ─────────────────────────────────────────────────────────────
# Points the frontend SSE client at the local Express server (local-backend.js)
VITE_FUNCTIONS_URL=http://localhost:3001

# Gemini API key readable by Node.js (local-backend.js reads this via dotenv)
GOOGLE_AI_API_KEY=your_gemini_api_key

# Firebase Admin SDK – service account key for Firestore access from local backend
# IMPORTANT: Store this file OUTSIDE the project folder so it never gets committed
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/firebase-service-account-key.json
