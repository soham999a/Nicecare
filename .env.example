# Firebase Client SDK Config
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Cloud Functions URL
# For local emulator:
VITE_FUNCTIONS_URL=http://127.0.0.1:5001/your-project-id/us-central1
# For production (set after first deploy):
# VITE_FUNCTIONS_URL=https://us-central1-your-project-id.cloudfunctions.net

# NOTE: VITE_GOOGLE_AI_API_KEY is no longer needed.
# The Gemini API key is now stored as a Cloud Functions secret.
# Set it with: firebase functions:secrets:set GOOGLE_AI_API_KEY
