rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Owner access that supports both direct master accounts and legacy owner profile shapes
    function isInventoryOwnerFor(ownerUid) {
      return isSignedIn() &&
        (
          request.auth.uid == ownerUid ||
          (
            exists(/databases/$(database)/documents/inventoryInternalUserProfiles/$(request.auth.uid)) &&
            (
              get(/databases/$(database)/documents/inventoryInternalUserProfiles/$(request.auth.uid)).data.role == 'master' ||
              get(/databases/$(database)/documents/inventoryInternalUserProfiles/$(request.auth.uid)).data.role == 'business owner'
            ) &&
            (
              get(/databases/$(database)/documents/inventoryInternalUserProfiles/$(request.auth.uid)).data.ownerUid == ownerUid ||
              get(/databases/$(database)/documents/inventoryInternalUserProfiles/$(request.auth.uid)).data.masterUid == ownerUid
            )
          )
        );
    }
    
    function isOwner(resourceData) {
      return isInventoryOwnerFor(resourceData.ownerUid);
    }

    // CRM internal user profile document - only owner can read/write
    match /crmInternalUserProfiles/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // External customer records: master owns, employees can read their store's customers
    match /externalCustomerRecords/{docId} {
      allow create: if isSignedIn() &&
        (request.resource.data.ownerUid == request.auth.uid ||
         isAssignedManagerForStore(request.resource.data.ownerUid, request.resource.data.storeId) ||
         (exists(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)) &&
          request.resource.data.ownerUid == getEmployeeOwnerUid() &&
          request.resource.data.storeId == getEmployeeStoreId()));
      allow read: if isOwner(resource.data) ||
        isAssignedManagerForStore(resource.data.ownerUid, resource.data.storeId) ||
        (isSignedIn() &&
         exists(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)) &&
         resource.data.storeId == getEmployeeStoreId() &&
         resource.data.ownerUid == getEmployeeOwnerUid());
      allow update: if isOwner(resource.data) ||
        isAssignedManagerForStore(resource.data.ownerUid, resource.data.storeId) ||
        (isSignedIn() &&
         exists(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)) &&
         resource.data.storeId == getEmployeeStoreId() &&
         resource.data.ownerUid == getEmployeeOwnerUid());
      allow delete: if isOwner(resource.data);
    }

    // ===== INVENTORY MANAGEMENT RULES =====

    // Inventory internal user profiles (master and staff accounts)
    match /inventoryInternalUserProfiles/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Helper function to check if user is master owner
    function isMasterOwner(resourceData) {
      return isInventoryOwnerFor(resourceData.ownerUid);
    }

    // Helper function to check if user is employee of the store
    function isStoreEmployee(storeId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)).data.assignedStoreId == storeId;
    }

    // Helper function to get employee's store ID
    function getEmployeeStoreId() {
      return get(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)).data.assignedStoreId;
    }

    // Helper function to get employee's owner UID
    function getEmployeeOwnerUid() {
      return get(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)).data.ownerUid;
    }

    function getEmployeeRole() {
      return get(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)).data.role;
    }

    function isAssignedManager(ownerUid, storeId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)) &&
        getEmployeeRole() == 'manager' &&
        getEmployeeStoreId() == storeId &&
        getEmployeeOwnerUid() == ownerUid;
    }

    // Fallback for managers who have inventoryInternalUserProfiles but no storeStaffAssignments doc (e.g. migration)
    function isAssignedManagerFromInventoryUsers(ownerUid, storeId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/inventoryInternalUserProfiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/inventoryInternalUserProfiles/$(request.auth.uid)).data.role == 'manager' &&
        get(/databases/$(database)/documents/inventoryInternalUserProfiles/$(request.auth.uid)).data.assignedStoreId == storeId &&
        (get(/databases/$(database)/documents/inventoryInternalUserProfiles/$(request.auth.uid)).data.ownerUid == ownerUid ||
         get(/databases/$(database)/documents/inventoryInternalUserProfiles/$(request.auth.uid)).data.masterUid == ownerUid);
    }

    function isAssignedManagerForStore(ownerUid, storeId) {
      return isAssignedManager(ownerUid, storeId) ||
        isAssignedManagerFromInventoryUsers(ownerUid, storeId);
    }

    // Business store locations - only master can CRUD their stores
    match /businessStoreLocations/{storeId} {
      allow create: if isInventoryOwnerFor(request.resource.data.ownerUid);
      allow read: if isMasterOwner(resource.data) || isStoreEmployee(storeId);
      allow update: if isMasterOwner(resource.data) ||
        (isAssignedManagerForStore(resource.data.ownerUid, storeId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['productCount', 'updatedAt']));
      allow delete: if isMasterOwner(resource.data);
    }

    // Store staff assignments - master can CRUD, employee can read their own and create their profile
    match /storeStaffAssignments/{employeeId} {
      // Master can create staff assignments with their ownerUid
      // Employee can create their own record during signup (employeeId must match their uid)
      allow create: if isSignedIn() && 
        (isInventoryOwnerFor(request.resource.data.ownerUid) || 
         (employeeId == request.auth.uid && request.resource.data.uid == request.auth.uid));
      // Master can read all their staff assignments, employee can read their own record
      // Manager can read staff in their store (from storeStaffAssignments or inventoryInternalUserProfiles)
      allow read: if isInventoryOwnerFor(resource.data.ownerUid) ||
        request.auth.uid == employeeId ||
        isAssignedManagerForStore(resource.data.ownerUid, resource.data.assignedStoreId);
      // Only master can update/delete
      allow update, delete: if isInventoryOwnerFor(resource.data.ownerUid);
    }

    // Inventory product catalog - master can CRUD, employee can read products from their store
    match /inventoryProductCatalog/{productId} {
      allow create: if isSignedIn() &&
        (isInventoryOwnerFor(request.resource.data.ownerUid) ||
         isAssignedManagerForStore(request.resource.data.ownerUid, request.resource.data.storeId));
      // Master can read all their products
      // Employee can read products from their assigned store
      allow read: if isMasterOwner(resource.data) || 
        isAssignedManagerForStore(resource.data.ownerUid, resource.data.storeId) ||
        (isSignedIn() && 
         exists(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)) && 
         resource.data.storeId == getEmployeeStoreId() &&
         resource.data.ownerUid == getEmployeeOwnerUid());
      // Master can update/delete
      // Employee can update stock quantity only (for sales)
      allow update: if isMasterOwner(resource.data) || 
        (isAssignedManagerForStore(resource.data.ownerUid, resource.data.storeId) &&
         request.resource.data.ownerUid == resource.data.ownerUid &&
         request.resource.data.storeId == resource.data.storeId) ||
        (isSignedIn() && 
         exists(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)) && 
         resource.data.storeId == getEmployeeStoreId() &&
         resource.data.ownerUid == getEmployeeOwnerUid() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity', 'updatedAt']));
      allow delete: if isMasterOwner(resource.data) ||
        isAssignedManagerForStore(resource.data.ownerUid, resource.data.storeId);
    }

    // Sales transaction records - master can read all, employee can create and read their store's sales
    match /salesTransactionRecords/{saleId} {
      // Master or employee can create sales with proper ownership
      allow create: if isSignedIn() && 
        (isInventoryOwnerFor(request.resource.data.ownerUid) ||
         isAssignedManagerForStore(request.resource.data.ownerUid, request.resource.data.storeId) ||
         (exists(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)) &&
          request.resource.data.ownerUid == getEmployeeOwnerUid() &&
          request.resource.data.storeId == getEmployeeStoreId()));
      // Master can read all their sales
      // Employee can read sales from their store
      allow read: if isMasterOwner(resource.data) ||
        isAssignedManagerForStore(resource.data.ownerUid, resource.data.storeId) ||
        (isSignedIn() && 
         exists(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)) && 
         resource.data.storeId == getEmployeeStoreId() &&
         resource.data.ownerUid == getEmployeeOwnerUid());
      // Generally sales should not be updated or deleted, but master can if needed
      allow update, delete: if isMasterOwner(resource.data);
    }

    // Inventory stock movement logs - tracks inventory changes
    match /inventoryStockMovementLogs/{movementId} {
      allow create: if isSignedIn() && 
        (isInventoryOwnerFor(request.resource.data.ownerUid) ||
         isAssignedManagerForStore(request.resource.data.ownerUid, request.resource.data.storeId) ||
         (exists(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)) &&
          request.resource.data.ownerUid == getEmployeeOwnerUid()));
      allow read: if isMasterOwner(resource.data) ||
        isAssignedManagerForStore(resource.data.ownerUid, resource.data.storeId) ||
        (isSignedIn() && 
         exists(/databases/$(database)/documents/storeStaffAssignments/$(request.auth.uid)) && 
         resource.data.storeId == getEmployeeStoreId() &&
         resource.data.ownerUid == getEmployeeOwnerUid());
      allow update, delete: if isMasterOwner(resource.data);
    }

    // Staff onboarding invitations - for invitation-based employee onboarding
    match /staffOnboardingInvitations/{invitationId} {
      // Master can create invitations with their ownerUid
      allow create: if isSignedIn() &&
        (isInventoryOwnerFor(request.resource.data.ownerUid) ||
         (request.resource.data.role == 'member' &&
          isAssignedManagerForStore(request.resource.data.ownerUid, request.resource.data.assignedStoreId)));
      // Anyone can read invitations (needed for signup flow to validate invite codes)
      allow read: if true;
      // Master can update/delete their invitations
      // Employee can update invitation to mark it as accepted (only status and acceptedAt/acceptedByUid fields)
      allow update: if isSignedIn() && 
        (isInventoryOwnerFor(resource.data.ownerUid) || 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'acceptedByUid']));
      allow delete: if isInventoryOwnerFor(resource.data.ownerUid);
    }

    // Migration history - owner accounts can read/write their own tenant history
    match /migrationHistory/{docId} {
      allow create: if isInventoryOwnerFor(request.resource.data.ownerUid);
      allow read, update, delete: if isInventoryOwnerFor(resource.data.ownerUid);
    }

    // ===== CHATBOT FEEDBACK RULES =====

    // Chatbot feedback submissions - users can create/read/update their own feedback
    match /chatbotFeedbackSubmissions/{docId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
    
    // Block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
