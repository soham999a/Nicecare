rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(resourceData) {
      return isSignedIn() && resourceData.ownerUid == request.auth.uid;
    }

    // User profile document - only owner can read/write
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Customers collection: each document must have ownerUid set to the user's UID
    match /customers/{docId} {
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read: if isOwner(resource.data);
      allow update, delete: if isOwner(resource.data);
    }

    // ===== INVENTORY MANAGEMENT RULES =====

    // Inventory Users collection (master accounts)
    match /inventoryUsers/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Helper function to check if user is master owner
    function isMasterOwner(resourceData) {
      return isSignedIn() && resourceData.ownerUid == request.auth.uid;
    }

    // Helper function to check if user is employee of the store
    function isStoreEmployee(storeId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.assignedStoreId == storeId;
    }

    // Helper function to get employee's store ID
    function getEmployeeStoreId() {
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.assignedStoreId;
    }

    // Helper function to get employee's owner UID
    function getEmployeeOwnerUid() {
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.ownerUid;
    }

    // Stores collection - only master can CRUD their stores
    match /stores/{storeId} {
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read: if isMasterOwner(resource.data) || isStoreEmployee(storeId);
      allow update, delete: if isMasterOwner(resource.data);
    }

    // Employees collection - master can CRUD, employee can read their own and create their profile
    match /employees/{employeeId} {
      // Master can create employees with their ownerUid
      // Employee can create their own record during signup (employeeId must match their uid)
      allow create: if isSignedIn() && 
        (request.resource.data.ownerUid == request.auth.uid || 
         (employeeId == request.auth.uid && request.resource.data.uid == request.auth.uid));
      // Master can read all their employees, employee can read their own record
      allow read: if (isSignedIn() && resource.data.ownerUid == request.auth.uid) || request.auth.uid == employeeId;
      // Only master can update/delete
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Products collection - master can CRUD, employee can read products from their store
    match /products/{productId} {
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      // Master can read all their products
      // Employee can read products from their assigned store
      allow read: if isMasterOwner(resource.data) || 
        (isSignedIn() && 
         exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && 
         resource.data.storeId == getEmployeeStoreId() &&
         resource.data.ownerUid == getEmployeeOwnerUid());
      // Master can update/delete
      // Employee can update stock quantity only (for sales)
      allow update: if isMasterOwner(resource.data) || 
        (isSignedIn() && 
         exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && 
         resource.data.storeId == getEmployeeStoreId() &&
         resource.data.ownerUid == getEmployeeOwnerUid() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity', 'updatedAt']));
      allow delete: if isMasterOwner(resource.data);
    }

    // Sales collection - master can read all, employee can create and read their store's sales
    match /sales/{saleId} {
      // Master or employee can create sales with proper ownership
      allow create: if isSignedIn() && 
        (request.resource.data.ownerUid == request.auth.uid ||
         (exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
          request.resource.data.ownerUid == getEmployeeOwnerUid() &&
          request.resource.data.storeId == getEmployeeStoreId()));
      // Master can read all their sales
      // Employee can read sales from their store
      allow read: if isMasterOwner(resource.data) ||
        (isSignedIn() && 
         exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && 
         resource.data.storeId == getEmployeeStoreId() &&
         resource.data.ownerUid == getEmployeeOwnerUid());
      // Generally sales should not be updated or deleted, but master can if needed
      allow update, delete: if isMasterOwner(resource.data);
    }

    // Stock Movements collection - tracks inventory changes
    match /stockMovements/{movementId} {
      allow create: if isSignedIn() && 
        (request.resource.data.ownerUid == request.auth.uid ||
         (exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
          request.resource.data.ownerUid == getEmployeeOwnerUid()));
      allow read: if isMasterOwner(resource.data) ||
        (isSignedIn() && 
         exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && 
         resource.data.storeId == getEmployeeStoreId() &&
         resource.data.ownerUid == getEmployeeOwnerUid());
      allow update, delete: if isMasterOwner(resource.data);
    }

    // Employee Invitations collection - for invitation-based employee onboarding
    match /employeeInvitations/{invitationId} {
      // Master can create invitations with their ownerUid
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      // Anyone can read invitations (needed for signup flow to validate invite codes)
      allow read: if true;
      // Master can update/delete their invitations
      // Employee can update invitation to mark it as accepted (only status and acceptedAt/acceptedByUid fields)
      allow update: if isSignedIn() && 
        (resource.data.ownerUid == request.auth.uid || 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'acceptedByUid']));
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
    
    // Block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
