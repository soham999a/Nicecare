{
  "name": "remote-shop-support",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend": "node local-backend.js",
    "dev:full": "concurrently -k -n VITE,BACKEND -c cyan,magenta \"npm run dev\" \"npm run backend\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "migrate:firestore-collections": "node functions/scripts/migrateFirestoreCollectionNames.js",
    "migrate:firestore-collections:write": "node functions/scripts/migrateFirestoreCollectionNames.js --write",
    "reconcile:inventory-consistency": "node functions/scripts/reconcileInventoryConsistency.js",
    "reconcile:inventory-consistency:write": "node functions/scripts/reconcileInventoryConsistency.js --write",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.2.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "firebase": "^12.7.0",
    "framer-motion": "^12.35.2",
    "lodash": "^4.17.23",
    "lucide-react": "^0.575.0",
    "mapbox-gl": "^3.19.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-map-gl": "^8.1.0",
    "react-router-dom": "^7.12.0",
    "recharts": "^3.8.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.17",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "express": "^5.2.1",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.17"
  }
}
